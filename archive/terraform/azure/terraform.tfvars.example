# ============================================================================
# Azure Terraform Variables - Example Configuration
# ============================================================================
# Copy this file to terraform.tfvars and update with your values
#
# Usage:
#   cp terraform.tfvars.example terraform.tfvars
#   # Edit terraform.tfvars with your actual values
#   terraform init
#   terraform plan
#   terraform apply

# ============================================================================
# General Configuration
# ============================================================================

# Azure region for deployment
azure_region = "eastus"

# Environment name (dev, staging, prod)
environment = "dev"

# AKS cluster name
cluster_name = "sis-analytics"

# Resource group name
resource_group_name = "sis-analytics-rg"

# ============================================================================
# AKS Configuration
# ============================================================================

# Kubernetes version
kubernetes_version = "1.28"

# Number of nodes in the cluster
node_count = 3

# VM size for AKS nodes
# Options: Standard_B2s, Standard_D2s_v3, Standard_D4s_v3, Standard_E4s_v3, etc.
vm_size = "Standard_D2s_v3"

# Enable autoscaling
enable_auto_scaling = true

# Minimum number of nodes for autoscaling
min_node_count = 2

# Maximum number of nodes for autoscaling
max_node_count = 10

# Enable RBAC
enable_rbac = true

# ============================================================================
# Network Configuration
# ============================================================================

# Network plugin (azure or kubenet)
network_plugin = "azure"

# CIDR range for Kubernetes services
service_cidr = "10.1.0.0/16"

# DNS service IP
dns_service_ip = "10.1.0.10"

# ============================================================================
# Database Configuration
# ============================================================================

# Database administrator login
db_administrator_login = "sis_admin"

# Database administrator password (required, sensitive)
# IMPORTANT: Change this to a strong password!
# Minimum 8 characters, must contain uppercase, lowercase, numbers
db_password = "ChangeMe@12345"

# PostgreSQL version
db_version = "14"

# Database SKU
# Options: B_Gen5_1, B_Gen5_2, GP_Gen5_2, GP_Gen5_4, GP_Gen5_8, MO_Gen5_2, MO_Gen5_4, etc.
db_sku_name = "B_Gen5_2"

# Database storage in MB (default: 102400 = 100 GB)
db_storage_mb = 102400

# Backup retention in days (7-35)
backup_retention_days = 30

# Enable geo-redundant backup
enable_geo_redundant_backup = false

# Enable SSL enforcement
enable_ssl_enforcement = true

# ============================================================================
# Storage Configuration
# ============================================================================

# Storage account tier (Standard or Premium)
storage_account_tier = "Standard"

# Storage replication type
# Options: LRS (Locally Redundant), GRS (Geo-Redundant), RAGRS (Read-access Geo-Redundant), ZRS (Zone-Redundant)
storage_replication_type = "GRS"

# Enable HTTPS traffic only
enable_https_traffic_only = true

# ============================================================================
# Tags
# ============================================================================

common_tags = {
  Project     = "OSS Framework"
  Module      = "SIS Analytics"
  ManagedBy   = "Terraform"
  Environment = "dev"
}

# ============================================================================
# Production Configuration Example
# ============================================================================

# For production deployment, use values similar to below:
# azure_region           = "eastus"
# environment            = "prod"
# cluster_name           = "sis-analytics-prod"
# kubernetes_version     = "1.28"
# node_count             = 5
# vm_size                = "Standard_D4s_v3"
# enable_auto_scaling    = true
# min_node_count         = 3
# max_node_count         = 20
# db_sku_name            = "GP_Gen5_4"
# db_storage_mb          = 512000  # 500 GB
# backup_retention_days  = 35
# enable_geo_redundant_backup = true
# storage_replication_type = "RAGRS"

# ============================================================================
# Development Configuration Example
# ============================================================================

# For development/testing, use values similar to below:
# azure_region           = "eastus"
# environment            = "dev"
# cluster_name           = "sis-analytics-dev"
# node_count             = 1
# vm_size                = "Standard_B2s"
# min_node_count         = 1
# max_node_count         = 3
# db_sku_name            = "B_Gen5_1"
# db_storage_mb          = 51200  # 50 GB
# backup_retention_days  = 7
