# ============================================================================
# AWS Terraform Variables - Example Configuration
# ============================================================================
# Copy this file to terraform.tfvars and update with your values
# 
# Usage:
#   cp terraform.tfvars.example terraform.tfvars
#   # Edit terraform.tfvars with your actual values
#   terraform init
#   terraform plan
#   terraform apply

# ============================================================================
# General Configuration
# ============================================================================

# AWS region for deployment
aws_region = "us-east-1"

# Environment name (dev, staging, prod)
environment = "dev"

# EKS cluster name
cluster_name = "sis-analytics"

# Kubernetes version
cluster_version = "1.28"

# ============================================================================
# EKS Node Configuration
# ============================================================================

# EC2 instance types for worker nodes
instance_types = ["t3.medium", "t3.large"]

# Desired number of worker nodes
desired_size = 3

# Minimum number of worker nodes for autoscaling
min_size = 2

# Maximum number of worker nodes for autoscaling
max_size = 10

# ============================================================================
# RDS Database Configuration
# ============================================================================

# Allocated storage in GB
db_allocated_storage = 100

# RDS instance class
# Options: db.t3.micro, db.t3.small, db.t3.medium, db.t3.large, db.r5.large, etc.
db_instance_class = "db.t3.medium"

# RDS database password (required, sensitive)
# IMPORTANT: Change this to a strong password!
# Minimum 8 characters, must contain uppercase, lowercase, numbers, and special characters
db_password = "ChangeMe@12345"

# Number of days to retain RDS backups
backup_retention_days = 30

# ============================================================================
# Network Configuration
# ============================================================================

# CIDR blocks allowed for public API access
# WARNING: Using 0.0.0.0/0 allows public access from anywhere
# For production, restrict this to your office IP or VPN
public_access_cidrs = ["0.0.0.0/0"]

# VPC CIDR block
vpc_cidr = "10.0.0.0/16"

# ============================================================================
# Production Configuration Example
# ============================================================================

# For production deployment, use values similar to below:
# aws_region           = "us-east-1"
# environment          = "prod"
# cluster_name         = "sis-analytics-prod"
# cluster_version      = "1.28"
# instance_types       = ["t3.large", "t3.xlarge"]
# desired_size         = 5
# min_size             = 3
# max_size             = 20
# db_allocated_storage = 500
# db_instance_class    = "db.t3.large"
# db_password          = "[SECURE_PASSWORD_HERE]"
# backup_retention_days = 90
# public_access_cidrs  = ["YOUR_OFFICE_IP/32", "YOUR_VPN_IP/32"]

# ============================================================================
# Development Configuration Example
# ============================================================================

# For development/testing, use values similar to below:
# aws_region           = "us-east-1"
# environment          = "dev"
# cluster_name         = "sis-analytics-dev"
# cluster_version      = "1.28"
# instance_types       = ["t3.micro", "t3.small"]
# desired_size         = 1
# min_size             = 1
# max_size             = 3
# db_allocated_storage = 20
# db_instance_class    = "db.t3.micro"
# backup_retention_days = 7
# public_access_cidrs  = ["YOUR_DEV_IP/32"]
