# Public example configuration for the local-data-stack OSS framework
# Copy to .env and replace placeholder values for your own environment.

# Aeries source configuration
AERIES_API_URL=https://api.aeries.com/v5
AERIES_AUTH_METHOD=api_key
AERIES_API_KEY=replace_with_your_aeries_api_key
# AERIES_CLIENT_ID=replace_with_your_client_id
# AERIES_CLIENT_SECRET=replace_with_your_client_secret
# AERIES_DB_HOST=replace_with_your_sql_server_host
# AERIES_DB_PORT=1433
# AERIES_DB_DATABASE=replace_with_your_database_name
# AERIES_DB_USERNAME=replace_with_your_username
# AERIES_DB_PASSWORD=replace_with_your_password

# Local lakehouse paths (repo-root relative)
DUCKDB_DATABASE_PATH=./oss_framework/data/oea.duckdb
STAGE1_PATH=./oss_framework/data/stage1
STAGE2_PATH=./oss_framework/data/stage2
STAGE3_PATH=./oss_framework/data/stage3

# Rill resolves paths relative to rill_project/
RILL_DUCKDB_DSN=../oss_framework/data/oea.duckdb
RILL_EXPORT_DIR=../../rill_project/data

# Runtime tuning
DUCKDB_MEMORY_LIMIT=8GB
DATA_RETENTION_YEARS=5
PSEUDONYMIZATION_LEVEL=full
AUDIT_LOGGING_ENABLED=true
LOG_LEVEL=INFO
LOG_FILE=./oss_framework/logs/local-data-stack.log
