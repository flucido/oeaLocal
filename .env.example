# AeRIES MotherDuck Data Mart Configuration
# Copy this file to .env and update values for your environment

# ============================================
# MOTHERDUCK CONFIGURATION (REQUIRED)
# ============================================
# MotherDuck is a managed DuckDB cloud service
# Get your token at: https://motherduck.com/docs/key-concepts/authentication
MOTHERDUCK_TOKEN=your_motherduck_token_here

# MotherDuck database name (will be created if it doesn't exist)
MOTHERDUCK_DATABASE=aeries_data_mart

# ============================================
# DUCKDB LOCAL CACHE CONFIGURATION
# ============================================
# Local DuckDB file for caching and offline development
# Relative to project root
DUCKDB_DATABASE_PATH=./oss_framework/data/oea.duckdb

# DuckDB memory limit (adjust based on available system RAM)
# Supports: MB, GB units (e.g., 8GB, 4096MB)
DUCKDB_MEMORY_LIMIT=8GB

# ============================================
# AERIES DATA SOURCE CONFIGURATION
# ============================================
# Full path to AeRIES test data directory
# Must contain CSV/Excel files exported from AeRIES SIS
AERIES_SOURCE_PATH=/Users/flucido/Desktop/AeRIES test data

# ============================================
# DATA LAKE STAGING PATHS
# ============================================
# Stage 1: Raw AeRIES data in Parquet format (normalized from CSV)
# Should include 'aeries' subdirectory for this data source
STAGE1_PATH=./oss_framework/data/stage1/aeries

# Stage 2: Transformed and deduplicated data
STAGE2_PATH=./oss_framework/data/stage2

# Stage 3: Analytics-ready tables for dashboards and reporting
STAGE3_PATH=./oss_framework/data/stage3

# ============================================
# DATA RETENTION & COMPLIANCE
# ============================================
# How many years to retain historical data
DATA_RETENTION_YEARS=5

# Archive graduated students to reduce active data size
ARCHIVE_GRADUATED_STUDENTS=true

# Pseudonymization level: full (no student names) or identified (with names)
PSEUDONYMIZATION_LEVEL=full

# Enable audit logging for data access and modifications
AUDIT_LOGGING_ENABLED=true

# ============================================
# LOGGING CONFIGURATION
# ============================================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log file location (relative to project root)
LOG_FILE=./oss_framework/logs/aeries_pipeline.log

# ============================================
# DEVELOPMENT/DEBUGGING (Optional)
# ============================================
# Enable verbose output during pipeline execution
DEBUG_MODE=false

# Profile performance of data transformations
ENABLE_PROFILING=false
