# ============================================================================
# Metabase Configuration - Environment Variables Template
# ============================================================================
# 
# INSTRUCTIONS:
# 1. Copy this file to .env in the same directory
# 2. Replace placeholder values with your actual credentials
# 3. Never commit the .env file to version control
#
# cp .env.example .env
# 

# ----------------------------------------------------------------------------
# Metabase Admin Credentials
# ----------------------------------------------------------------------------
# These credentials are used to authenticate with Metabase API
# Set these after completing initial Metabase setup at http://localhost:3000

METABASE_EMAIL=admin@your-district.edu
METABASE_PASSWORD=your-secure-password-here

# ----------------------------------------------------------------------------
# Metabase Connection Settings
# ----------------------------------------------------------------------------
# URL for the primary Metabase instance (oss-metabase)
# Default: http://localhost:3000

METABASE_URL=http://localhost:3000

# ----------------------------------------------------------------------------
# Database Configuration
# ----------------------------------------------------------------------------
# Path to DuckDB database file (inside container)
# This path is mapped from host: oss_framework/data/oea.duckdb

DUCKDB_PATH=/data/oea.duckdb

# Database display name in Metabase UI
DUCKDB_DATABASE_NAME=OSS Analytics

# Schema containing analytics views
DUCKDB_SCHEMA=main_main_analytics

# ----------------------------------------------------------------------------
# Optional: Secondary Metabase Instance (Legacy)
# ----------------------------------------------------------------------------
# The sis-metabase instance runs on port 3001 (from main docker-compose.yml)
# Only configure if you need to work with the legacy instance

# SIS_METABASE_URL=http://localhost:3001
# SIS_METABASE_EMAIL=admin@your-district.edu
# SIS_METABASE_PASSWORD=your-secure-password-here

# ----------------------------------------------------------------------------
# Dashboard Refresh Settings
# ----------------------------------------------------------------------------
# Cache TTL for dashboard queries (in minutes)
CACHE_TTL_MINUTES=10

# Auto-refresh interval for dashboards (in minutes)
REFRESH_INTERVAL_MINUTES=5

# ----------------------------------------------------------------------------
# Collection Organization
# ----------------------------------------------------------------------------
# Name of the collection that contains all OSS dashboards
COLLECTION_NAME=OSS Analytics

# Whether to clean up old dashboards/questions before creating new ones
CLEANUP_OLD_DASHBOARDS=true
