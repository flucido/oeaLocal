# ============================================================================
# GCP Terraform Variables - Example Configuration
# ============================================================================
# Copy this file to terraform.tfvars and update with your values
#
# Usage:
#   cp terraform.tfvars.example terraform.tfvars
#   # Edit terraform.tfvars with your actual values
#   gcloud auth application-default login
#   terraform init
#   terraform plan
#   terraform apply

# ============================================================================
# General Configuration
# ============================================================================

# GCP project ID (required)
# Get this from: gcloud config get-value project
gcp_project_id = "YOUR_GCP_PROJECT_ID"

# GCP region for deployment
gcp_region = "us-central1"

# Environment name (dev, staging, prod)
environment = "dev"

# GKE cluster name
cluster_name = "sis-analytics"

# ============================================================================
# GKE Configuration
# ============================================================================

# Kubernetes version
kubernetes_version = "1.28"

# Enable network policy
enable_network_policy = true

# Enable HTTP load balancing
enable_http_load_balancing = true

# Enable horizontal pod autoscaling
enable_horizontal_pod_autoscaling = true

# ============================================================================
# Node Pool Configuration
# ============================================================================

# Node pool name
node_pool_name = "default-pool"

# Initial number of nodes
node_count = 3

# Machine type
# Options: n1-standard-1, n1-standard-2, n1-standard-4, e2-medium, e2-standard-2, etc.
machine_type = "n1-standard-2"

# Boot disk size in GB
disk_size_gb = 50

# Use preemptible nodes (lower cost, no SLA)
preemptible = true

# Enable autoscaling
enable_autoscaling = true

# Minimum nodes for autoscaling
min_node_count = 2

# Maximum nodes for autoscaling
max_node_count = 10

# ============================================================================
# Network Configuration
# ============================================================================

# VPC network name
network_name = "sis-analytics-network"

# Subnet name
subnet_name = "sis-analytics-subnet"

# Subnet CIDR range
subnet_cidr = "10.0.0.0/20"

# Secondary range name for pods
pods_secondary_range_name = "pods"

# Secondary CIDR range for pods
pods_secondary_range_cidr = "10.4.0.0/14"

# Secondary range name for services
services_secondary_range_name = "services"

# Secondary CIDR range for services
services_secondary_range_cidr = "10.8.0.0/20"

# ============================================================================
# Cloud SQL Configuration
# ============================================================================

# PostgreSQL version
database_version = "POSTGRES_15"

# Cloud SQL instance tier
# Options: db-f1-micro, db-g1-small, db-custom-1-3840, db-custom-2-7680, etc.
database_tier = "db-f1-micro"

# Initial database storage in GB (for shared tier, use 10-100)
database_storage_gb = 100

# Database username
db_username = "sis_admin"

# Database password (required, sensitive)
# IMPORTANT: Change this to a strong password!
# Minimum 8 characters
db_password = "ChangeMe@12345"

# Enable point-in-time recovery
enable_point_in_time_recovery = true

# Backup retention in days (0-35)
backup_retention_days = 30

# Enable deletion protection
enable_deletion_protection = false

# ============================================================================
# Cloud Storage Configuration
# ============================================================================

# Storage bucket location
storage_bucket_location = "US"

# Force destroy bucket (delete even if not empty)
storage_bucket_force_destroy = false

# Enable versioning
storage_versioning_enabled = true

# ============================================================================
# Production Configuration Example
# ============================================================================

# For production deployment, use values similar to below:
# gcp_region                = "us-central1"
# environment               = "prod"
# cluster_name              = "sis-analytics-prod"
# kubernetes_version        = "1.28"
# node_count                = 5
# machine_type              = "n1-standard-4"
# preemptible               = false
# min_node_count            = 3
# max_node_count            = 20
# database_version          = "POSTGRES_15"
# database_tier             = "db-custom-4-15360"  # Custom machine
# backup_retention_days     = 35
# enable_deletion_protection = true
# enable_point_in_time_recovery = true

# ============================================================================
# Development Configuration Example
# ============================================================================

# For development/testing, use values similar to below:
# gcp_region                = "us-central1"
# environment               = "dev"
# cluster_name              = "sis-analytics-dev"
# node_count                = 1
# machine_type              = "e2-medium"
# preemptible               = true
# min_node_count            = 1
# max_node_count            = 3
# database_tier             = "db-f1-micro"
# database_storage_gb       = 10
# backup_retention_days     = 7
# storage_bucket_force_destroy = true
